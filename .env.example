# ============================================================
# Claude Skills Agentic Executor — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Required — OpenAI / ChatOpenAI
# ----------------------------------------------------------

# OpenAI API key (used by langchain-openai / ChatOpenAI)
OPENAI_API_KEY=sk-xxxxx

# Custom OpenAI-compatible API base URL (optional)
# OPENAI_API_BASE=https://your-custom-endpoint.example.com/v1

# ----------------------------------------------------------
# Core Agent LLM Models (src/skills_agent/nodes.py)
# ----------------------------------------------------------

# Model used by Planner & Evaluator (reasoning-heavy tasks)
# THINKING_MODEL=gpt-oss

# Model used by Optimizer (fast tool-calling tasks)
# DENSE_MODEL=gpt-oss

# ----------------------------------------------------------
# Gemini API (used by gemini_search, video, embeddings, sandbox)
# ----------------------------------------------------------

# Google Gemini API key
# GEMINI_API_KEY=xxxxx

# Gemini model for video processing (default: gemini-2.0-flash)
# GEMINI_VIDEO_MODEL=gemini-2.0-flash

# Gemini model for text embeddings (default: text-embedding-004)
# GEMINI_TEXT_EMBED_MODEL=text-embedding-004

# Gemini model for code sandbox execution (default: gemini-2.5-flash)
# GEMINI_SANDBOX_MODEL=gemini-2.5-flash

# ----------------------------------------------------------
# Temporal Graph Scripts (scripts/create_temporal_graph.py,
#   scripts/inference_with_graph.py)
# ----------------------------------------------------------

# LLM endpoint for temporal graph extraction (falls back to OPENAI_API_BASE)
# TEMPORAL_GRAPH_API_BASE=https://your-endpoint.example.com/v1

# LLM API key for temporal graph extraction (falls back to OPENAI_API_KEY)
# TEMPORAL_GRAPH_API_KEY=sk-xxxxx

# Model for temporal graph operations (default: gpt-oss)
# TEMPORAL_GRAPH_MODEL=gpt-oss

# ----------------------------------------------------------
# Anthropic API (used by web_search.py and Claude native skills)
# ----------------------------------------------------------

# Anthropic API key (required for web search and document generation skills)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ----------------------------------------------------------
# Transcript API (used by ects_skill)
# ----------------------------------------------------------

# API URL for the earnings call transcript service
# TRANSCRIPT_API_URL=https://your-transcript-api.example.com/v1/transcripts

# Bearer token for the transcript API
# TRANSCRIPT_API_TOKEN=your-api-token-here

# ----------------------------------------------------------
# Optional — LangSmith observability
# ----------------------------------------------------------

# Set to "true" to enable LangSmith tracing
# LANGCHAIN_TRACING_V2=true

# LangSmith API key (required when tracing is enabled)
# LANGCHAIN_API_KEY=lsv2_xxxxx

# LangSmith project name (defaults to "default")
# LANGCHAIN_PROJECT=skills-agent
